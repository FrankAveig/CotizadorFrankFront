# SPA (React + BrowserRouter) bajo /cotizaciones/
# Coloca el contenido de `dist` en la carpeta `cotizaciones` del servidor
# y asegúrate de que este .htaccess se copie ahí (Vite lo toma desde public/).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /cotizaciones/

  # Archivos y carpetas reales (assets, favicon, index.html)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Cualquier otra ruta → index.html (React Router)
  RewriteRule ^ index.html [L]
</IfModule>
